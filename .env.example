# ============================================================
# Shellton Auto Mecânica — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores do Supabase:
#   cp .env.example .env
# ============================================================

# URL do projeto (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (Settings → API → Publishable key ou anon key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Alternativa aceita pelo código (use uma ou outra):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
